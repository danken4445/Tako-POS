{
  "expo": {
    "name": "TakoPOS",
    "slug": "TakoPOS",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/TakoPOS-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/TakoPOS-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/TakoPOS-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.danken.TakoPOS"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-secure-store",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "d0925f49-3b3c-4c1c-9f6f-f220eb9081ae"
      }
    }
  }
}
